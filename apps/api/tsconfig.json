{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node16",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@watchblitz/types": ["../../packages/types/src"],
      "@watchblitz/config": ["../../packages/config/src"],
      "@watchblitz/utils": ["../../packages/utils/src"],
      "@watchblitz/database": ["../../packages/database/src"]
